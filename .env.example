# .env.example
# 실제 값을 채운 뒤 파일명을 .env로 바꿔서 사용하세요.
# .env 자체는 절대 깃허브에 커밋하지 마세요 (.gitignore에 반드시 포함).

# Supabase 대시보드 > Connect 버튼에서 확인
# 지금 단계(FastAPI를 계속 떠있는 서버로 배포)라면 Session pooler(5432) 권장
# 서버리스/엣지로 배포한다면 Transaction pooler(6543)로 바꾸세요
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# LLM 호출용 (기존 persona_eval_*.py에서 쓰던 키)
GEMINI_API_KEY=your-gemini-api-key-here
